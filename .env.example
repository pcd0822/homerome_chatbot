# =============================================================================
# 학급 챗봇 환경 변수 템플릿
# - 로컬에서는 이 파일을 복사해 `.env` 또는 `.env.local` 로 저장하고 값을 채웁니다.
# - 배포 환경(Netlify)에서는 Site settings → Environment variables 에 등록합니다.
# - 이 파일에는 절대 실제 값을 넣지 마세요(GitHub에 올라갑니다).
# =============================================================================

# --- LLM API 키 (사용할 모델의 키만 채우면 됩니다) ---
VITE_ANTHROPIC_API_KEY=
VITE_OPENAI_API_KEY=
VITE_GEMINI_API_KEY=

# --- 노션 MCP (Claude 모델에서만 사용) ---
# URL 기본값은 노션 공식. 사내 프록시가 있으면 그 URL로 교체.
VITE_NOTION_MCP_URL=https://mcp.notion.com/mcp
VITE_NOTION_MCP_TOKEN=

# --- Google Drive MCP (운영자가 제공하는 엔드포인트로 교체) ---
VITE_GOOGLE_DRIVE_MCP_URL=
VITE_GOOGLE_DRIVE_MCP_TOKEN=
