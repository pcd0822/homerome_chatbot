# =============================================================================
# 학급 챗봇 환경 변수 템플릿
# - 로컬에서는 이 파일을 복사해 `.env` 또는 `.env.local` 로 저장하고 값을 채웁니다.
# - 배포 환경(Netlify)에서는 Site settings → Environment variables 에 등록합니다.
# - 이 파일에는 절대 실제 값을 넣지 마세요(GitHub에 올라갑니다).
# =============================================================================

# --- LLM API 키 (사용할 모델의 키만 채우면 됩니다) ---
VITE_ANTHROPIC_API_KEY=
VITE_OPENAI_API_KEY=
VITE_GEMINI_API_KEY=

# --- 노션 MCP (Claude 모델에서만 사용) ---
# URL 기본값은 노션 공식 호스팅 MCP. SSE 방식은 /sse 로 교체.
# 토큰은 OAuth Bearer 토큰. Internal Integration Secret(ntn_...)으로는 동작하지 않습니다.
# OAuth 토큰 발급: `npx @modelcontextprotocol/inspector` → Quick OAuth Flow.
VITE_NOTION_MCP_URL=https://mcp.notion.com/mcp
VITE_NOTION_MCP_TOKEN=

# 학급 노션 메인 페이지 URL (선택). 등록하면 Claude가 검색 시 우선 참고합니다.
# Claude 가 자동으로 이 URL 기준으로 학급 정보를 가져옵니다.
VITE_NOTION_PAGE_URL=

# --- Google Drive (서비스 계정 + 폴더 ID 방식) ---
# 1) Google Cloud Console 에서 Service Account 생성
# 2) JSON 키 발급 → client_email, private_key 두 값을 분해해서 등록
# 3) 학급 자료를 둘 Drive 폴더에 그 서비스 계정 이메일을 "뷰어" 권한으로 공유
# 4) 폴더 URL 의 마지막 부분이 folder ID:
#      https://drive.google.com/drive/folders/<여기가_FOLDER_ID>
#
# Tip: 가장 간단한 방법은 서비스 계정 JSON 파일 전체를 작은따옴표로 감싸서
# VITE_GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY 에 넣는 것입니다. 그러면 앱이 자동으로
# private_key / client_email 을 꺼내 씁니다. (EMAIL 변수는 비워둬도 됩니다.)
#   예) VITE_GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY='{"type":"service_account",...}'
#
# 분해해서 넣고 싶다면 PEM 그대로 큰따옴표로 감싸서 넣으세요.
#   예) VITE_GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
VITE_GOOGLE_SERVICE_ACCOUNT_EMAIL=
VITE_GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
VITE_GOOGLE_DRIVE_FOLDER_ID=
