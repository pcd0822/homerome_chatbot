# =============================================================================
# 학생용 멀티 LLM 탐구 챗봇 — 환경 변수 템플릿
# -----------------------------------------------------------------------------
# ⚠️ 이 키들은 서버(Netlify Functions)에서만 읽습니다. VITE_ 접두사를 붙이지
#    마세요 — 붙이면 프론트엔드 번들에 노출됩니다. 키는 절대 브라우저로 가지
#    않습니다(브라우저는 /api/chat 만 호출).
#
# - 로컬 개발: 이 파일을 복사해 `.env` 로 저장하고 값을 채운 뒤 `netlify dev`.
# - 배포: Netlify → Site settings → Environment variables 에 등록.
# - 이 파일(.env.example)에는 절대 실제 값을 넣지 마세요(GitHub 에 올라갑니다).
# - 사용할 모델의 키만 채우면 됩니다(있는 것만 UI 에서 선택 가능).
# =============================================================================

# Claude (Anthropic)
ANTHROPIC_API_KEY=

# GPT (OpenAI)
OPENAI_API_KEY=

# Gemini (Google)
GEMINI_API_KEY=
